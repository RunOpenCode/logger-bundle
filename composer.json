{
    "name": "runopencode/logger-bundle",
    "description": "Symfony integration with runopencode/logger component.",
    "license": "MIT",
    "authors": [
        {
            "name": "Nikola Svitlica a.k.a TheCelavi",
            "email": "thecelavi@runopencode.com"
        },
        {
            "name": "Stefan Veljancic",
            "email": "veljancicstefan@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.4",
        "psr/log": "^3.0",
        "runopencode/logger": "^0.2",
        "symfony/config": "^7.0",
        "symfony/http-kernel": "^7.0",
        "symfony/dependency-injection": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "RunOpenCode\\Bundle\\LoggerBundle\\": "src/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../Component/Logger",
            "options": {
                "symlink": false
            }
        }
    ],
    "config": {
        "sort-packages": true
    },
    "version": "0.2",
    "minimum-stability": "dev",
    "prefer-stable": true
}
